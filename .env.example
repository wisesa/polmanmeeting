# Firebase Admin SDK. Ambil dari Firebase Console > Project settings > Service accounts.
FIREBASE_SERVICE_ACCOUNT_PATH=./polman-635e0-firebase-adminsdk-fbsvc-79d2864d27.json
FIREBASE_PROJECT_ID=polman-635e0
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@polman-635e0.iam.gserviceaccount.com

# Firebase Web App Config. Wajib untuk login admin Firebase Authentication.
# Ambil dari Firebase Console > Project settings > General > Your apps > Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=isi_api_key_web_app
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=polman-635e0.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=polman-635e0
NEXT_PUBLIC_FIREBASE_APP_ID=isi_app_id_web_app

# Opsional. Jika kosong, semua user Firebase Auth bisa masuk admin.
# Isi dengan email admin, pisahkan koma bila lebih dari satu.
ADMIN_EMAILS=

# face-api.js berjalan di browser. CDN ini bisa diganti ke /models/face-api bila model disimpan lokal.
NEXT_PUBLIC_FACE_API_MODEL_URL=https://cdn.jsdelivr.net/gh/justadudewhohacks/face-api.js/weights
FACE_API_DISTANCE_THRESHOLD=0.6

NEXT_PUBLIC_APP_NAME=Polman Meeting Web
