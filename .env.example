# Firebase Web App config
NEXT_PUBLIC_FIREBASE_API_KEY=isi_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=isi_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=isi_project_id
NEXT_PUBLIC_NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=isi_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=isi_app_id

# Firebase Admin SDK, pilih salah satu pola berikut.
# Opsi 1: JSON service account yang di-base64-kan.
FIREBASE_SERVICE_ACCOUNT_BASE64=isi_base64_service_account_json

# Opsi 2: isi manual field service account.
FIREBASE_PROJECT_ID=isi_project_id
FIREBASE_CLIENT_EMAIL=isi_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Admin Firebase Auth yang boleh masuk /admin/login.
# Untuk keamanan, jangan dikosongkan.
ADMIN_EMAILS=admin@polman-babel.ac.id

# Sesi login wajah dosen.
# Wajib pakai string random panjang agar cookie sesi aman.
DOSEN_SESSION_SECRET=ganti_dengan_secret_random_panjang

# Threshold face-api.js. Semakin kecil semakin ketat.
# Nilai 0.6 terlalu longgar untuk absensi/login karena dapat memicu false positive.
# Endpoint login dan absensi sekarang memakai batas ketat bawaan 0.45.
# Ubah hanya setelah diuji dengan banyak data wajah kampus.
FACE_API_DISTANCE_THRESHOLD=0.45
FACE_API_LOGIN_DISTANCE_THRESHOLD=0.45
FACE_API_ATTENDANCE_DISTANCE_THRESHOLD=0.45

# Jarak minimal antara kandidat wajah terbaik dan kandidat kedua.
# Jika selisih terlalu kecil, sistem menolak sebagai wajah ambigu.
FACE_API_MIN_DISTANCE_GAP=0.04
FACE_API_LOGIN_MIN_DISTANCE_GAP=0.04
FACE_API_ATTENDANCE_MIN_DISTANCE_GAP=0.04
NEXT_PUBLIC_FACE_API_MODEL_URL=/models/face-api

# Gambar meeting disimpan sebagai base64 di dokumen Firestore.
# Tidak perlu Firebase Storage bucket atau Vercel Blob.
